<!DOCTYPE html>
<html>
  <head>
    <title>GAMEVIEWS</title>
    <!-- bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    >

    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/form.css" />

  </head>
  <body>
    <%- include('modules/header.ejs') %>

    <main>
      <section>
        <h1 class="text-center p-3 bg-dark text-white">Comparte una review</h1>
        <br>
        <div class="form-div bg-secondary container-fluid">
          <form 
            action="/game/shareUser/<%= user_id %>" 
            method="post" 
            enctype="multipart/form-data"
            class="text-black fs-5"
          >
          <input for="user_id" value="<%= user_id %>" disabled>
            <div>
              <label 
                for="title" 
                class="text-black"
                >Título del juego
              </label>
              <br>
              <input 
                type="text" 
                id="title"
                name="title"
              >                    
              </div>
              
              <div>        
              <label for="" class="pt-2">Valoración</label>
              <input type="number" min="1" max="5" name="rating" id="rating">
              </div>
              <div>
              <label 
                for="platform" 
                class="text-black"
                >Plataforma
              </label>
              <select 
                name="platform" 
                id="platform" 
                placeholder="Selecciona una plataforma" 
                >
                <option disabled selected>Selecciona una plataforma</option>
                <option value="PlayStation">PlayStation</option>
                <option value="PC">PC</option>
                <option value="Nintendo">Nintendo</option>
                <option value="Juegos de mesa">Juegos de mesa</option>
              </select>                   
              </div>
              <div>
              <label for="" class="pt-2">Año de publicación</label>
              <br>
              <input 
                type="text" 
                id="release_year"
                name="release_year"
              
              >
              </div>
              <div>
              <label for="" class="pt-2">Review</label>
              <br>
              <textarea 
                type="text" 
                name="review"
                id="review"
              ></textarea>              
            </div>
            <div class="pt-1 pb-3 d-flex" style="gap:1rem;">
              <label for="file" class="button btn btn-warning">Portada
                <input type="file" id="file" hidden name="img">
              </label>
              
              <div class="text-warning">
                <%= message %>
              </div>
            </div>
            <div class="text-center">
              <button class="btn btn-info">Enviar</button>
              <button class="btn btn-info" type="reset">Limpiar</button>
              <a href="/" class="btn btn-info">Cancelar</a>
            </div>
          </form>
            </div>

            <div class="p-3"></div>
      </section>
    </main>
    <%- include('modules/links.ejs') %>
    <%- include('modules/footer.ejs') %>
    
  </body>
</html>