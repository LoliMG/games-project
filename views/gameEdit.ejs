<!DOCTYPE html>
<html>
  <head>
    <title>GAMEVIEWS</title>
    <!-- bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    >

    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/form.css" />

  </head>
  <body>
    <%- include('modules/header.ejs') %>

    <main>
      <section>
        <h1 class="text-center p-3 bg-dark text-white">Editar: <%= gameToEdit.title %> de </h1>
        <br>
        <div class="form-div bg-secondary container-fluid">
          <form 
            action='/game/gameEdit/<%= gameToEdit.game_id %>/<%= gameToEdit.user_id %>' 
            method="post" 
            class="text-black fs-5"
          >
          <div>
            <label for="">Usuario</label>
            <br>
            <input name="" id="" required value="<%= gameToEdit.user_id %>">             
          </div>
            <div>
              <label for="" class="text-black">Título del juego</label>
              <br>
              <input 
                type="text" 
                name="title"
                value="<%= gameToEdit.title %>"
              >                    
              </div>
              <div>
              <label for="" class="text-black">Plataforma</label>
              <select name="" id="" value="<%= gameToEdit.platform %>">
                <option value="PlayStation">PlayStation</option>
                <option value="PC">PC</option>
                <option value="Nintendo">Nintendo</option>
                <option value="Juegos de mesa">Juegos de mesa</option>
              </select>                   
              </div>
              <div>        
              <label for="" class="pt-2">Valoración</label>
              <input type="number" max="5" min="1" id="" value="<%= gameToEdit.rating %>">
              </div>
              <div>
              <label for="" class="pt-2">Año de publicación</label>
              <br>
              <input 
                type="text" 
                name="release_year"
                value="<%= gameToEdit.release_year %>"
              >
              </div>
              <div>
              <label for="" class="pt-2">Review</label>
              <br>              
              <textarea 
                type="text" 
                name="review"
                value="<%= gameToEdit.review %>"
              ></textarea>              
            </div>
            <div class="pt-1 pb-3">
              <label for="file" class="button btn btn-warning">Portada
                <input 
                  type="file" 
                  id="file" 
                  hidden 
                  name="img" 
                  value="<%= gameToEdit.cover %>">
              </label>
            </div>
            <div class="text-center">
              <button class="btn btn-info">Enviar</button>
              <button class="btn btn-info" type="reset">Limpiar</button>
              <a href="/" class="btn btn-info">Cancelar</a>
            </div>
          </form>
            </div>
      </section>
      <div class="p-3"></div>
    </main>
    <%- include('modules/links.ejs') %>
    <%- include('modules/footer.ejs') %>
    
  </body>
</html>