<!DOCTYPE html>
<html>
  <head>
    <title>GAMEVIEWS</title>
    <%- include('modules/headlink.ejs') %>

    <link rel="stylesheet" href="/stylesheets/index.css" />
    <link rel="stylesheet" href="/stylesheets/gameLists.css" />


  </head>
  <body>
    <%- include('modules/header.ejs') %>

    <main class="tomorrow-regular">

      <section class="section-users">
        <h2 class="text-center bg-dark bg-gradient p-4">JUEGOS DE ORDENADOR</h2>      
      <div class="back-game d-flex flex-wrap p-5">
        <% game.forEach((elem) => { %>
        <div class="row">
          <div class="col">
          <img 
            src="/images/games/<%= elem.cover %>" 
            class="" 
            alt="..."            
          > 
          <div class="game-text text-center bg-dark">
          <p>Publicado por:  
            <a class="text-warning" href="/user/userX/<%= elem.user_id %>"> 
               <%= elem.name %>
            </a> 
          </p>
          </div>
          </div>
        </div>        
        <% }); %>
      </div>
      </section>

    
    </main>

    <%- include('modules/footer.ejs') %>
    <%- include('modules/links.ejs') %>
  </body>
</html>
