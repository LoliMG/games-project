<!DOCTYPE html>
<html>
  <head>
    <title>GAMEVIEWS</title>
    <!-- bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    >

    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/form.css" />

  </head>

  
  <body>
    <%- include('modules/header.ejs') %>

    <main>
      <section>
        <h1 class="text-center p-3 bg-dark text-white">Formulario de registro</h1>
        <br>
        <div class="form-div bg-secondary container-fluid">
          <form 
            action="/user/register" 
            method="post" 
            enctype="multipart/form-data"
            class="text-black fs-5"
          >
            <div>
              <label for="" class="text-black">Nombre de usuario</label>
              <br>
              <input 
                type="text" 
                name="name"
              >      
              </div>
              <div>        
              <label for="" class="pt-2">Email</label>
              <br>
              <input 
                type="text" 
                name="email"
              >
              </div>
              <div>
              <label for="" class="pt-2">Contraseña</label>
              <br>
              <input 
                type="text" 
                name="password"
              >
              </div>
              <div>
              <label for="" class="pt-2">Bio</label>
              <br>
              <textarea 
                type="text" 
                name="bio"
              ></textarea>              
            </div>
            <div class="pt-3 pb-3">
              <label 
                for="file" 
                class="button btn btn-warning">Avatar
                <input 
                  type="file" 
                  class="form-control"
                  id="file" 
                  hidden 
                  name="img">
              </label>

              <div class="text-danger"><%= message %></div>              
            </div>
            <div class="text-center">
              <button class="btn btn-info">Enviar</button>
              <button class="btn btn-info" type="reset">Limpiar</button>
              <a href="/" class="btn btn-info">Cancelar</a>
            </div>
          </form>
            </div>
      </section>
      

    
    </main>
    <%- include('modules/links.ejs') %>
    <%- include('modules/footer.ejs') %>
    
  </body>
</html>
